VITE_BASE44_APP_ID=local_app
VITE_BASE44_APP_BASE_URL=http://localhost:5173
VITE_BASE44_LEGACY_SDK_IMPORTS=false
APP_BASE_URL=http://localhost:5173

# Server-only AI provider keys. Do not prefix these with VITE_.
AQ_API_KEY=
AQ_MODEL=gemini-2.0-flash
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Server-only news provider keys. Do not prefix these with VITE_.
GOOGLE_NEWS_API_KEY=
NEWSDATA_API_KEY=
NEWSAPI_API_KEY=

# Public no-key weather endpoints.
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
OPEN_METEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# Provider-generated OAuth authorization URLs. Their secure backend callback
# should return to /files?cloud_connected=1&cloud_provider=<provider>.
VITE_GOOGLE_DRIVE_AUTH_URL=
VITE_ONEDRIVE_AUTH_URL=
VITE_DROPBOX_AUTH_URL=
