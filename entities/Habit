{
  "name": "Habit",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "icon": {
      "type": "string",
      "default": "circle-check"
    },
    "color": {
      "type": "string",
      "enum": [
        "blue",
        "green",
        "red",
        "orange",
        "purple",
        "pink"
      ],
      "default": "blue"
    },
    "frequency": {
      "type": "string",
      "enum": [
        "daily",
        "weekly"
      ],
      "default": "daily"
    },
    "target_count": {
      "type": "number",
      "default": 1
    },
    "completions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "count": {
            "type": "number",
            "default": 1
          }
        }
      }
    },
    "current_streak": {
      "type": "number",
      "default": 0
    },
    "best_streak": {
      "type": "number",
      "default": 0
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}